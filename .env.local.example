# =============================================================================
# Ketan BizLife LP — Example .env.local (safe to commit)
# Copy this file to .env.local and fill in real values.
# =============================================================================

# --- Razorpay ---
# Get from https://dashboard.razorpay.com/app/keys
# Use rzp_test_... for development, rzp_live_... for production
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# --- Pabbly Connect webhook ---
# Full HTTPS URL from your Pabbly Connect workflow
PABBLY_WEBHOOK_URL=https://connect.pabbly.com/workflow/sendwebhookdata/IjU3NjY...

# --- Meta Conversions API (optional but enabled for this project) ---
# Get Pixel ID from Events Manager → Data Sources
# Generate Access Token from Events Manager → Settings → Conversions API
META_PIXEL_ID=123456789012345
META_CAPI_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
